			alwaysTransparent = yes
		}

		instantTextboxType = {
			name = acow_title
			font = malgun_goth_24
			position = { x = 0 y = 10 }
			maxWidth = @width1
			maxHeight = 30
			alwaysTransparent = yes
			fixedSize = no
			format = center
			text = acow_starcage_management_title
			text_color_code = G
