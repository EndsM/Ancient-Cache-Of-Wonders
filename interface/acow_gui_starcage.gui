		}
		
		iconType = { name = empire_info_bg spriteType = GFX_diplomacy_dark_fade_bg position = { x = 9999 y = 9999 } }
		
		# Leader details container (Required)
		containerWindowType = {
			name = leader_details
			position = { x = 9999 y = 9999 }
			containerWindowType = { name = empire_traits_box position = { x = 0 y = 0 } size = { width = 1 height = 1 } }
			instantTextBoxType = { name = empire_traits_label font = cg_16b position = { x = 0 y = 0 } maxWidth = 1 }
			overlappingElementsBoxType = { name = leader_traits position = { x = 0 y = 0 } size = { x = 1 y = 1 } }
			instantTextBoxType = { name = leader_name font = cg_16b position = { x = 0 y = 0 } maxWidth = 1 }
			instantTextBoxType = { name = leader_species font = cg_16b position = { x = 0 y = 0 } maxWidth = 1 }
		}
		
		# Opinion Window container (Required)
		containerWindowType = {
			name = opinion_window
			position = { x = 9999 y = 9999 }
			size = { width = 94 height = 30 }
			iconType = { name = their_opinion_icon spriteType = GFX_diplomacy_opinion }
			instantTextBoxType = { name = their_opinion font = cg_16b maxWidth = 40 position = { x = 0 y = 0 } }
