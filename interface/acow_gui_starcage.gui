		# --- Standard Event Integration ---
		containerWindowType = {
			name = EVENT_DIPLO
			position = { x = 0 y = -40 }
			size = { width = @width2 height = 32 }
			orientation = center_down
			origo = center_down

			instantTextBoxType = {
				name = action_title
				font = malgun_goth_24
				position = { x = 9999 y = 9999 }
				maxWidth = 1
			}
			instantTextBoxType = {
				name = action_desc
				font = malgun_goth_24
				position = { x = 9999 y = 9999 }
				maxWidth = 1
			}

			listboxType = {
				name = option_list
				position = { x = 180 y = 0 }
				size = { width = 280 height = 40 }
				spacing = 1
				scrollbartype = standardlistbox_slider
				borderSize = { x = 0 y = 0 }
			}
		}

		# --- Hidden Paradox Elements (Required to prevent crashes) ---
		buttonType = { name = tts_button position = { x = 9999 y = 9999 } spriteType = GFX_button_tts_start }
		instantTextBoxType = { name = heading font = malgun_goth_24 position = { x = 9999 y = 9999 } maxWidth = 1 }
		instantTextBoxType = { name = alien_message font = cg_16b position = { x = 9999 y = 9999 } maxWidth = 1 }
		instantTextBoxType = { name = empire_name font = cg_16b position = { x = 9999 y = 9999 } maxWidth = 1 }
		instantTextBoxType = { name = empire_government_type font = cg_16b position = { x = 9999 y = 9999 } maxWidth = 1 }
		instantTextBoxType = { name = empire_personality_type font = cg_16b position = { x = 9999 y = 9999 } maxWidth = 1 }
		buttonType = { name = focus_button position = { x = 9999 y = 9999 } spriteType = GFX_fleetview_focus }
		buttonType = { name = empire_flag position = { x = 9999 y = 9999 } spriteType = GFX_empire_flag_128 }
		buttonType = { name = confirm_button quadTextureSprite = GFX_standard_button_142_34_button position = { x = 9999 y = 9999 } font = "cg_16b" text = "MESSAGE_OK" }
		
		containerWindowType = {
			name = portrait_background
			position = { x = 9999 y = 9999 }
