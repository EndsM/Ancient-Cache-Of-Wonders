guiTypes = {
	@width1 = 660
	@width2 = 640
	containerWindowType = {
		name = acow_starcage_world_option
		position = { x = 0 y = 0 }
		size = { x = 280 y = 40 }
		moveable = no
		buttonType = {
			name = option_button
